# Works with any OpenAI-compatible endpoint:
# - OpenAI:        leave OPENAI_BASE_URL empty, set OPENAI_API_KEY
# - DeepSeek:      OPENAI_BASE_URL=https://api.deepseek.com/v1
# - Qwen (DashScope-compat): OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# - Local vLLM:    OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=

# Loop-engineering best practice: a stronger model writes, a cheaper one verifies.
AGENT_MODEL=gpt-4o-mini
VERIFIER_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini
