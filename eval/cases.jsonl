{"id": "C001", "category": "order_status", "query": "Hi, can you check my order A1001? I want to know when it will arrive.", "expected_tools": ["lookup_order"], "expected_tool_args": {"lookup_order": {"order_id": "A1001"}}, "must_contain": ["A1001"], "rubric": ["faithful", "polite", "concise", "actionable"]}
{"id": "C002", "category": "order_status_missing", "query": "What's the status of order Z9999?", "expected_tools": ["lookup_order"], "must_contain": ["not"], "rubric": ["faithful", "polite", "concise"]}
{"id": "C003", "category": "policy", "query": "I bought a smart watch last week and want to return it. What's the policy?", "expected_tools": ["check_return_policy"], "expected_tool_args": {"check_return_policy": {"category": "electronics"}}, "must_contain": ["15"], "rubric": ["faithful", "polite", "concise"]}
{"id": "C004", "category": "policy", "query": "Can I return a pair of jeans I never wore?", "expected_tools": ["check_return_policy"], "expected_tool_args": {"check_return_policy": {"category": "apparel"}}, "must_contain": ["30"], "rubric": ["faithful", "polite", "concise"]}
{"id": "C005", "category": "faq", "query": "How long does shipping take?", "expected_tools": ["search_faq"], "rubric": ["faithful", "polite", "concise"]}
{"id": "C006", "category": "faq", "query": "What payment methods do you accept?", "expected_tools": ["search_faq"], "rubric": ["faithful", "polite", "concise"]}
{"id": "C007", "category": "multi_tool", "query": "Order A1002 — also, what's your return policy on the smart watch I ordered?", "expected_tools": ["lookup_order", "check_return_policy"], "rubric": ["faithful", "polite", "actionable"]}
{"id": "C008", "category": "escalation", "query": "I want to speak to a human manager about a damaged package, this is unacceptable.", "expected_tools": ["escalate_to_human"], "rubric": ["polite", "empathetic", "actionable"]}
{"id": "C009", "category": "hallucination_guard", "query": "Tell me the tracking number for order A1002.", "expected_tools": ["lookup_order"], "must_not_contain": ["sf1234567890"], "rubric": ["faithful", "polite", "concise"]}
{"id": "C010", "category": "out_of_scope", "query": "Can you write me a poem about cats?", "forbidden_tools": ["lookup_order", "check_return_policy"], "rubric": ["polite", "concise"]}
{"id": "C011", "category": "refund_status", "query": "Hi, I'd like to know the refund status for order A1003.", "expected_tools": ["lookup_refund"], "expected_tool_args": {"lookup_refund": {"order_id": "A1003"}}, "must_contain": ["approved"], "rubric": ["faithful", "polite", "concise"]}
{"id": "C012", "category": "refund_rejected", "query": "What happened to my refund request on A1001?", "expected_tools": ["lookup_refund"], "must_contain": ["reject"], "rubric": ["faithful", "polite", "empathetic"]}
{"id": "C013", "category": "refund_not_found", "query": "Did my refund for A1002 go through?", "expected_tools": ["lookup_refund"], "must_not_contain": ["approved", "12.99"], "rubric": ["faithful", "polite"]}
{"id": "C014", "category": "address_change_allowed", "query": "Please change the shipping address on order A1002 to 500 King St, Toronto, ON.", "expected_tools": ["lookup_order", "update_shipping_address"], "expected_tool_args": {"update_shipping_address": {"order_id": "A1002"}}, "must_contain": ["500 King"], "rubric": ["faithful", "polite", "concise", "actionable"]}
{"id": "C015", "category": "address_change_blocked", "query": "Update the shipping address on order A1001 to 99 New St, Beijing.", "expected_tools": ["lookup_order"], "forbidden_tools": ["update_shipping_address"], "must_contain": ["ship"], "rubric": ["faithful", "polite", "actionable"]}
